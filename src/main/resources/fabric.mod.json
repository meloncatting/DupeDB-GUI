{
  "schemaVersion": 1,
  "id": "dupedbgui",
  "version": "${version}",
  "name": "DupeDB GUI",
  "description": "A mod to fetch data from DupeDB and display it in-game",
  "authors": [
    "SQD Studios",
    "Chamogelastos"
  ],
  "contact": {
    "homepage": "https://docs.chamosmp.net",
    "issues": "https://github.com/SQD-Studios/DupeDB-GUI/issues",
    "sources": "https://github.com/SQD-Studios/DupeDB-GUI"
  },
  "license": "MIT",
  "icon": "assets/dupedbgui/icongui.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "net.chamosmp.dupedbgui.client.DupedbguiDataGenerator"
    ],
    "client": [
      "net.chamosmp.dupedbgui.client.DupedbguiClient"
    ],
    "main": [
      "net.chamosmp.dupedbgui.Dupedbgui"
    ]
  },
  "mixins": [
    "dupedbgui.mixins.json",
    {
      "config": "dupedbgui.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "minecraft": "1.21.11"
  },

  "custom": {
    "modmenu": {
      "update_checker": true
    }
  }
}
